{
  "benchmarks": {
    "cpu-dgemm": {
      "workload_type": "cpu_compute",
      "phase": "phase1",
      "source_dir": "benchmarks/cpu-dgemm/src",
      "binary": "benchmarks/cpu-dgemm/bin/cpu_dgemm",
      "build": {
        "command": "{cxx} {cxxflags} -fopenmp benchmarks/cpu-dgemm/src/cpu_dgemm.cpp -o benchmarks/cpu-dgemm/bin/cpu_dgemm"
      },
      "default_env": {
        "OMP_PROC_BIND": "close",
        "OMP_PLACES": "cores"
      },
      "variants": {
        "smoke": {
          "args": "--m 256 --n 256 --k 256 --iters 2 --block 32"
        },
        "phase0": {
          "args": "--m 1024 --n 1024 --k 1024 --iters 3 --block 64"
        },
        "aurora": {
          "args": "--m 8192 --n 8192 --k 8192 --iters 5 --block 96"
        },
        "smoke_60s": {
          "_note": "Naive blocked OpenMP DGEMM (no MKL). 4096^3 = 137 GFLOP/iter; assume 80-400 GF/s aggregate on a Xeon Max node -> 40 iters lands roughly in [15, 70] s. Re-tune iters after first real run.",
          "args": "--m 4096 --n 4096 --k 4096 --iters 40 --block 64"
        },
        "smoke_15s": {
          "_note": "~15 s target: 10 iters of 4096^3 (~1.37 TFLOP total at ~80-400 GF/s aggregate). Re-tune after first real run.",
          "args": "--m 4096 --n 4096 --k 4096 --iters 10 --block 64"
        },
        "all_tiles_15s": {
          "_note": "CPU bench -- 'all tiles' is meaningless here; alias of smoke_15s so one VARIANT env works across all benches in submit_phase0_all.pbs.",
          "args": "--m 4096 --n 4096 --k 4096 --iters 10 --block 64"
        },
        "all_tiles_45s": {
          "_note": "3x work vs all_tiles_15s. ~30s wall at default, up to ~90s under cap-bound levels. Designed for prod-queue long sweeps where richer per-cell telemetry matters.",
          "args": "--m 4096 --n 4096 --k 4096 --iters 30 --block 64"
        }
      },
      "metric_keys": ["runtime_s", "avg_iter_s", "avg_gflops", "best_gflops", "checksum"]
    },
    "stream": {
      "workload_type": "cpu_memory",
      "phase": "phase1",
      "binary": "benchmarks/stream/src/stream",
      "build": {
        "command": "{cc} {cflags} -fopenmp -DSTREAM_ARRAY_SIZE={stream_array_size} -DNTIMES={stream_ntimes} -o benchmarks/stream/src/stream benchmarks/stream/src/stream.c"
      },
      "default_env": {
        "OMP_PROC_BIND": "close",
        "OMP_PLACES": "cores"
      },
      "variants": {
        "smoke": {
          "args": ""
        },
        "phase0": {
          "args": ""
        },
        "hbm": {
          "prefix": "numactl --membind=${HBM_NUMA_NODE}",
          "args": ""
        },
        "flat": {
          "prefix": "numactl --membind=${DDR_NUMA_NODE}",
          "args": ""
        },
        "smoke_60s": {
          "_note": "STREAM size is build-time (STREAM_ARRAY_SIZE, STREAM_NTIMES). For a ~60s run on HBM (~1 TB/s/socket), build with STREAM_ARRAY_SIZE=268435456 STREAM_NTIMES=20000 (one binary serves all variants).",
          "args": ""
        },
        "smoke_15s": {
          "_note": "~15 s target: build with STREAM_ARRAY_SIZE=268435456 STREAM_NTIMES=5000 (one binary serves all variants).",
          "args": ""
        },
        "all_tiles_15s": {
          "_note": "CPU bench -- alias of smoke_15s so one VARIANT env works across all benches.",
          "args": ""
        },
        "all_tiles_45s": {
          "_note": "Stream runtime is build-time. For 3x duration on DDR (~67s), rebuild with: STREAM_NTIMES=2100 ./scripts/build_benchmark.sh stream  (default NTIMES=700 gives ~22s on DDR.) Args stay empty; the binary chosen at build time decides the work amount.",
          "args": ""
        }
      },
      "metric_keys": ["runtime_s", "triad_bandwidth_mb_s"]
    },
    "dgemm-gpu": {
      "workload_type": "gpu_compute",
      "phase": "phase1",
      "binary": "benchmarks/dgemm-gpu/bin/gpu_dgemm_sycl",
      "build": {
        "command": "{sycl_cxx} {sycl_cxxflags} benchmarks/dgemm-gpu/src/gpu_dgemm_sycl.cpp -o benchmarks/dgemm-gpu/bin/gpu_dgemm_sycl"
      },
      "default_env": {
        "ZES_ENABLE_SYSMAN": "1"
      },
      "variants": {
        "smoke": {
          "env": {"ONEAPI_DEVICE_SELECTOR": "opencl:cpu"},
          "args": "--M 256 --N 256 --K 256 --iters 2"
        },
        "phase0": {
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "--M 1024 --N 1024 --K 1024 --iters 5"
        },
        "single_tile": {
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "--M 2048 --N 2048 --K 2048 --dtype double --iters 10"
        },
        "single_card": {
          "env": {"ZE_AFFINITY_MASK": "0"},
          "args": "--M 4096 --N 4096 --K 4096 --dtype double --iters 10"
        },
        "smoke_60s": {
          "_note": "All 12 PVC tiles concurrently for ~60 s wall. 12 MPI ranks * 200 iters of 4096^3 each. Per-tile time ~30-90 s; aggregate ~12x.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--M 4096 --N 4096 --K 4096 --dtype double --iters 200"
        },
        "smoke_15s": {
          "_note": "~15 s target on one PVC tile: 50 iters of 4096^3.",
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "--M 4096 --N 4096 --K 4096 --dtype double --iters 50"
        },
        "all_tiles_15s": {
          "_note": "All 12 PVC tiles concurrently. 12 MPI ranks * 50 iters of 4096^3 each. Each tile has independent HBM stack -> no contention; wall ~= per-tile time ~15 s, aggregate work ~12x.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--M 4096 --N 4096 --K 4096 --dtype double --iters 50"
        },
        "all_tiles_45s": {
          "_note": "3x all_tiles_15s. 12 MPI ranks * 150 iters of 4096^3 each. Wall ~45 s at default, up to ~135 s under aggressive caps.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--M 4096 --N 4096 --K 4096 --dtype double --iters 150"
        }
      },
      "metric_keys": ["runtime_s", "gflops"]
    },
    "babelstream": {
      "workload_type": "gpu_memory",
      "phase": "phase1",
      "binary": "benchmarks/babelstream/bin/mini_babelstream_sycl",
      "build": {
        "command": "{sycl_cxx} {sycl_cxxflags} benchmarks/babelstream/src/mini_babelstream_sycl.cpp -o benchmarks/babelstream/bin/mini_babelstream_sycl"
      },
      "default_env": {
        "ZES_ENABLE_SYSMAN": "1"
      },
      "variants": {
        "smoke": {
          "env": {"ONEAPI_DEVICE_SELECTOR": "opencl:cpu"},
          "args": "-s 1048576 --iters 3"
        },
        "phase0": {
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "-s 16777216 --iters 20"
        },
        "single_tile": {
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "-s 268435456 --iters 20"
        },
        "single_card": {
          "env": {"ZE_AFFINITY_MASK": "0"},
          "args": "-s 536870912 --iters 20"
        },
        "smoke_60s": {
          "_note": "All 12 PVC tiles concurrently. Each rank does 7000 iters of 2 GiB Triad on its tile (~30-90 s). Per-tile HBM is independent -> ~60 s wall, ~12x aggregate BW.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "-s 268435456 --iters 7000"
        },
        "smoke_15s": {
          "_note": "~15 s target on one PVC tile: 1800 iters of the same Triad size.",
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "-s 268435456 --iters 1800"
        },
        "all_tiles_15s": {
          "_note": "All 12 PVC tiles concurrently. 12 ranks * 1800 iters of 2 GiB Triad each. Per-tile HBM is independent -> ~15 s wall, ~12x aggregate BW.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "-s 268435456 --iters 1800"
        },
        "all_tiles_45s": {
          "_note": "3x all_tiles_15s. 12 ranks * 5400 iters of 2 GiB Triad each. Wall ~45 s at default.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "-s 268435456 --iters 5400"
        }
      },
      "metric_keys": ["runtime_s", "triad_bandwidth_mb_s"]
    },
    "osu": {
      "workload_type": "mpi_communication",
      "phase": "phase1",
      "binary": "benchmarks/osu/bin/mini_osu_collective",
      "build": {
        "command": "{mpicxx} {mpicxxflags} benchmarks/osu/src/mini_osu_collective.cpp -o benchmarks/osu/bin/mini_osu_collective"
      },
      "default_env": {
        "ZES_ENABLE_SYSMAN": "1"
      },
      "variants": {
        "smoke": {
          "args": "--collective allreduce -m 1:1024 --iters 10 --warmup 2"
        },
        "allreduce_4node": {
          "launcher": "mpiexec -n 32",
          "args": "--collective allreduce -m 1:8388608 --iters 100 --warmup 10"
        },
        "allreduce_8node": {
          "launcher": "mpiexec -n 64",
          "args": "--collective allreduce -m 1:8388608 --iters 100 --warmup 10"
        },
        "alltoall_4node": {
          "launcher": "mpiexec -n 32",
          "args": "--collective alltoall -m 1:8388608 --iters 100 --warmup 10"
        },
        "smoke_60s": {
          "_note": "Intra-node allreduce only. 12 ranks default (override via MPI_RANKS). Message range up to 32 MiB; --iters 4000 is a rough target for [40, 90] s. Least confident sizing — re-tune after first run.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--collective allreduce -m 1:33554432 --iters 4000 --warmup 50"
        },
        "smoke_15s": {
          "_note": "~9 s target intra-node allreduce: 120 iters (60% of previous 200). Tuned so osu finishes alongside slower benches under the BOARD cap sweep.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--collective allreduce -m 1:33554432 --iters 120 --warmup 10"
        },
        "all_tiles_15s": {
          "_note": "MPI bench -- alias of smoke_15s so one VARIANT env works across all benches.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--collective allreduce -m 1:33554432 --iters 120 --warmup 10"
        },
        "all_tiles_45s": {
          "_note": "3x all_tiles_15s. 360 iters. Wall ~30 s at default; up to ~250 s on aggressive board caps.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--collective allreduce -m 1:33554432 --iters 360 --warmup 30"
        }
      },
      "metric_keys": ["runtime_s", "latency_us"]
    },
    "mpi-idle-wait": {
      "workload_type": "mpi_slack",
      "phase": "phase1",
      "binary": "benchmarks/mpi-idle-wait/bin/mpi_idle_wait",
      "build": {
        "command": "{mpicxx} {mpicxxflags} benchmarks/mpi-idle-wait/src/mpi_idle_wait.cpp -o benchmarks/mpi-idle-wait/bin/mpi_idle_wait"
      },
      "default_env": {
        "ZES_ENABLE_SYSMAN": "1"
      },
      "variants": {
        "smoke": {
          "args": "--compute-ms 1 --wait-ms 1 --iterations 3 --mode barrier"
        },
        "barrier": {
          "launcher": "mpiexec -n ${MPI_RANKS:-32}",
          "args": "--compute-ms 20 --wait-ms 20 --iterations 500 --mode barrier"
        },
        "allreduce_skew": {
          "launcher": "mpiexec -n ${MPI_RANKS:-32}",
          "args": "--compute-ms 20 --wait-ms 80 --skew-rank 0 --iterations 500 --mode allreduce"
        },
        "smoke_60s": {
          "_note": "Deterministic ~60 s: 1000 iter * (30 ms compute + 30 ms wait) = 60 s. 12 ranks default; override via MPI_RANKS.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--compute-ms 30 --wait-ms 30 --iterations 1000 --mode barrier"
        },
        "smoke_15s": {
          "_note": "Deterministic ~15 s: 250 iter * (30 ms compute + 30 ms wait) = 15 s.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--compute-ms 30 --wait-ms 30 --iterations 250 --mode barrier"
        },
        "all_tiles_15s": {
          "_note": "MPI bench -- alias of smoke_15s so one VARIANT env works across all benches.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--compute-ms 30 --wait-ms 30 --iterations 250 --mode barrier"
        },
        "all_tiles_45s": {
          "_note": "Deterministic ~45 s: 750 iter * (30 ms compute + 30 ms wait) = 45 s.",
          "launcher": "mpiexec -n ${MPI_RANKS:-12}",
          "args": "--compute-ms 30 --wait-ms 30 --iterations 750 --mode barrier"
        }
      },
      "metric_keys": ["runtime_s", "compute_s", "wait_s"]
    },
    "gpu-bursty-idle": {
      "workload_type": "gpu_bursty_idle",
      "phase": "phase1",
      "binary": "benchmarks/gpu-bursty-idle/bin/gpu_bursty_idle",
      "build": {
        "command": "{sycl_cxx} {sycl_cxxflags} benchmarks/gpu-bursty-idle/src/gpu_bursty_idle.cpp -o benchmarks/gpu-bursty-idle/bin/gpu_bursty_idle"
      },
      "default_env": {
        "ZES_ENABLE_SYSMAN": "1"
      },
      "variants": {
        "smoke": {
          "env": {"ONEAPI_DEVICE_SELECTOR": "opencl:cpu"},
          "args": "--kernel-ms 2 --gap-ms 2 --iterations 3 --gap-mode sleep --elements 1048576"
        },
        "sleep_gap": {
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "--kernel-ms 20 --gap-ms 80 --iterations 500 --gap-mode sleep"
        },
        "cpu_gap": {
          "env": {"ZE_AFFINITY_MASK": "0"},
          "args": "--kernel-ms 20 --gap-ms 80 --iterations 500 --gap-mode cpu"
        },
        "smoke_60s": {
          "_note": "All 12 PVC tiles concurrently. Deterministic ~60 s wall (1000 iter * 60 ms). 12 tiles in lockstep bursting then idling -- best workload for measuring full-node GPU idle-power leakage vs gap-mode.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--kernel-ms 30 --gap-ms 30 --iterations 1000 --gap-mode sleep --elements 4194304"
        },
        "smoke_15s": {
          "_note": "Deterministic ~15 s: 250 iter * (30 ms kernel + 30 ms sleep gap) = 15 s. Single PVC tile.",
          "env": {"ZE_AFFINITY_MASK": "0.0"},
          "args": "--kernel-ms 30 --gap-ms 30 --iterations 250 --gap-mode sleep --elements 4194304"
        },
        "all_tiles_15s": {
          "_note": "All 12 PVC tiles concurrently. Deterministic ~15 s wall (250 iter * 60 ms = 15 s) but with 12 tiles in lockstep bursting then idling -- best workload for measuring GPU idle-power leakage vs gap-mode.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--kernel-ms 30 --gap-ms 30 --iterations 250 --gap-mode sleep --elements 4194304"
        },
        "all_tiles_45s": {
          "_note": "Deterministic ~45 s: 12 tiles in lockstep, 750 iter * (30 ms kernel + 30 ms sleep gap) = 45 s.",
          "launcher": "mpiexec -n 12 -ppn 12",
          "prefix": "scripts/per_tile_env.sh",
          "args": "--kernel-ms 30 --gap-ms 30 --iterations 750 --gap-mode sleep --elements 4194304"
        }
      },
      "metric_keys": ["runtime_s", "kernel_s", "gap_s"]
    }
  }
}
