{
  "_description": "Canonical strict-controls list shared by every Phase 1 sweep via include_knobs. 35 knobs (11 power_energy incl. POWERCAP aliases + 24 frequency incl. SST family). Drawn from docs/signals_and_controls/geopm_research_strict_controls.md.",
  "knobs": [
    {
      "name": "BOARD_POWER_LIMIT_CONTROL",
      "domain": "board",
      "instances": "auto",
      "reason": "Whole-node PL1; the headline cap. Literal watts: Aurora's BOARD_POWER_LIMIT_CONTROL defaults to 0.0 (no cap) so scale_readback is a no-op. From a baseline cpu-dgemm smoke, BOARD_POWER ran 1970-2555 W (mean 2444 W); caps below 2400 W bind. lit_3000W is the user's named headline scenario.",
      "levels": [
        {"label": "default", "kind": "default"},
        {"label": "lit_4000W", "kind": "literal", "value": 4000},
        {"label": "lit_3500W", "kind": "literal", "value": 3500},
        {"label": "lit_3000W", "kind": "literal", "value": 3000},
        {"label": "lit_2500W", "kind": "literal", "value": 2500},
        {"label": "lit_2000W", "kind": "literal", "value": 2000}
      ]
    },
    {
      "name": "BOARD_POWER_TIME_WINDOW_CONTROL",
      "domain": "board",
      "instances": "auto",
      "reason": "PL1 averaging window for the board cap; affects how aggressively the cap is enforced.",
      "levels": [
        {"label": "default", "kind": "default"},
        {"label": "readback_half", "kind": "scale_readback", "scale": 0.5},
        {"label": "readback_double", "kind": "scale_readback", "scale": 2.0}
      ]
    },
