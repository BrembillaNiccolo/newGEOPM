        {"label": "default", "kind": "default"},
        {"label": "tdp_90pct", "kind": "scale_signal", "signal": "CPU_POWER_LIMIT_DEFAULT", "scale": 0.90},
        {"label": "tdp_75pct", "kind": "scale_signal", "signal": "CPU_POWER_LIMIT_DEFAULT", "scale": 0.75},
        {"label": "tdp_60pct", "kind": "scale_signal", "signal": "CPU_POWER_LIMIT_DEFAULT", "scale": 0.60}
      ]
    },
