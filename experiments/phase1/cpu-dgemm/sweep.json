      "levels": [
        {"label": "default", "kind": "default"},
        {"label": "range_80", "kind": "fraction_range", "fraction": 0.80, "min_signal": "CPU_FREQUENCY_MIN_AVAIL", "max_signal": "CPU_FREQUENCY_MAX_AVAIL"},
        {"label": "range_60", "kind": "fraction_range", "fraction": 0.60, "min_signal": "CPU_FREQUENCY_MIN_AVAIL", "max_signal": "CPU_FREQUENCY_MAX_AVAIL"}
      ]
    },
    {
      "name": "CPU_POWER_LIMIT_CONTROL",
      "domain": "package",
      "instances": "auto",
      "reason": "RAPL package PL1; useful if power limiting performs cleaner than direct frequency limiting.",
      "levels": [
        {"label": "default", "kind": "default"},
        {"label": "default_90pct", "kind": "scale_signal", "signal": "CPU_POWER_LIMIT_DEFAULT", "scale": 0.90},
        {"label": "default_80pct", "kind": "scale_signal", "signal": "CPU_POWER_LIMIT_DEFAULT", "scale": 0.80}
