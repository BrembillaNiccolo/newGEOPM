        {"label": "range_55", "kind": "fraction_range", "fraction": 0.55, "min_signal": "GPU_CORE_FREQUENCY_MIN_AVAIL", "max_signal": "GPU_CORE_FREQUENCY_MAX_AVAIL"}
      ]
    }
